{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SnapCode",
  "version": "0.2.0",
  "identifier": "com.snapcode.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "SnapCode",
        "width": 420,
        "height": 680,
        "decorations": false,
        "minWidth": 360,
        "minHeight": 480
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDJDRkQxNUJBOUMyNUFEMUQKUldRZHJTV2N1aFg5TEE0cUMwUVRwbmNHbUZja3JiVmZUQXViQTR3MVRQMkRyTXBPOEk4OS9TK2QK",
      "endpoints": [
        "https://github.com/Dream-XJ/snapcode/releases/latest/download/latest.json"
      ]
    }
  }
}
